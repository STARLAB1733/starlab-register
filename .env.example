# Vercel KV — auto-added when you connect a KV database in Vercel dashboard
KV_REST_API_URL=https://your-kv-url.upstash.io
KV_REST_API_TOKEN=your-token-here
KV_REST_API_READ_ONLY_TOKEN=your-read-only-token-here

# S1 admin passphrase — set in Vercel project settings, share with S1 only
ADMIN_PASSWORD=change-me-to-a-strong-passphrase
